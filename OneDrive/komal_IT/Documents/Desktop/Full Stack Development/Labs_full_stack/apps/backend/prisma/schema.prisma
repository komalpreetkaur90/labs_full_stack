generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Role {
  id        Int        @id @default(autoincrement())
  name      String     @unique
  employees Employee[]
}

model Employee {
  id        Int    @id @default(autoincrement())
  firstName String
  lastName  String
  roleId    Int
  role      Role   @relation(fields: [roleId], references: [id])
}
